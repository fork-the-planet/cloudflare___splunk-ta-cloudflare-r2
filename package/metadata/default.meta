# Application-level permissions
[]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

# Processed-key checkpoint collection. The modular input (system session key,
# owner=nobody / app=TA_cloudflare_r2) reads and writes this collection; grant
# write to the admin roles that run modular inputs. export=system so KV Store
# recreates it in the app namespace on restart.
[collections/TA_cloudflare_r2_processed_keys]
access = read : [ * ], write : [ admin, sc_admin ]
export = system
